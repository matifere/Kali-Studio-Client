# Cloudflare Pages — control de caché para Flutter web
# Los archivos de entrada NUNCA se cachean, así un deploy nuevo se ve al instante.

/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/flutter_bootstrap.js
  Cache-Control: no-cache, no-store, must-revalidate

/flutter.js
  Cache-Control: no-cache, no-store, must-revalidate

/main.dart.js
  Cache-Control: no-cache, no-store, must-revalidate

/flutter_service_worker.js
  Cache-Control: no-cache, no-store, must-revalidate

/version.json
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.json
  Cache-Control: no-cache, no-store, must-revalidate

/push-sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# OJO: Flutter NO pone hash en los nombres de los assets (.env, AssetManifest,
# fuentes, imágenes, canvaskit.wasm se llaman igual en todos los builds), así
# que NO pueden cachearse como inmutables: los usuarios quedarían con la
# versión vieja hasta un año. "no-cache" permite guardarlos pero obliga a
# revalidar con ETag en cada carga: 304 barato si no cambiaron, versión nueva
# al instante si hubo deploy.
/assets/*
  Cache-Control: no-cache, must-revalidate

/canvaskit/*
  Cache-Control: no-cache, must-revalidate

/icons/*
  Cache-Control: no-cache, must-revalidate
