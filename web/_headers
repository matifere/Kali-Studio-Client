# Cloudflare Pages — control de caché para Flutter web
# Los archivos de entrada NUNCA se cachean, así un deploy nuevo se ve al instante.

/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/flutter_bootstrap.js
  Cache-Control: no-cache, no-store, must-revalidate

/flutter.js
  Cache-Control: no-cache, no-store, must-revalidate

/main.dart.js
  Cache-Control: no-cache, no-store, must-revalidate

/flutter_service_worker.js
  Cache-Control: no-cache, no-store, must-revalidate

/version.json
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.json
  Cache-Control: no-cache, no-store, must-revalidate

/push-sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Assets con hash en el nombre: se cachean fuerte (son inmutables por build).
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/canvaskit/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=31536000, immutable
